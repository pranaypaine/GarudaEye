# Runtime Mode
MODE=local  # or 'cloud'

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=pretty  # or 'json'

# Database (Local Mode)
DATABASE_URL=sqlite://./data/garudaeye.db

# Database (Cloud Mode)
# DATABASE_URL=postgres://user:password@localhost:5432/garudaeye

# Redis (Cloud Mode only)
# REDIS_URL=redis://localhost:6379

# AWS Credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Multi-Region Scanning
# AWS_REGIONS=us-east-1,us-west-2,eu-west-1, all (for all regions)
# Comma-separated list of AWS regions to scan
# Global services (CloudFront, Route53) are only collected once in us-east-1

# Azure Credentials
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# GCP Credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# DigitalOcean
# DIGITALOCEAN_TOKEN=

# Oracle Cloud
# OCI_CONFIG_FILE=/path/to/.oci/config
# OCI_PROFILE=DEFAULT

# Security Analyzers
# SHODAN_API_KEY=
# VIRUSTOTAL_API_KEY=
# OBSERVATORY_API_KEY=

# Worker Configuration
WORKER_COUNT=4
COLLECTOR_TIMEOUT_SECS=300
ANALYZER_TIMEOUT_SECS=60
